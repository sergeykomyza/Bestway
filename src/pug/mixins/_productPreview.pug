mixin productPreview(img, name, article, price)
	a.swiper-slide(href="product.html") 
		article.product-preview
			figure.product-preview__imagebox 
				.rating.product-preview__rating
					.rating__stars
						each item, i in [1, 2, 3, 4, 5]
							if(i == 4)
								img.rating__star.is-empty(src="img/icon-star.svg", alt="star")
							else 
								img.rating__star(src="img/icon-star.svg", alt="star")
					output.rating__quantity (12)
				img.product-preview__img(src="img/" + img, alt= name)
			.product-preview__info 
				h6.product-preview__name= name 
				span.product-preview__article= article 
				.product-preview__price 
					output= price 
					| руб