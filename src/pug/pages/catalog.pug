				.catalog__section 
					h6.section-title Акционные товары
					p.catalog__info Бесплатная доставка
					.swiper.products-carousel.catalog__slider.js-catalogSlider 
						.swiper-wrapper
							+productPreview('product-15.jpg', 'Надувной SPA-бассейн с гидромассажной ванной для 2-4 человек Lay-Z-Spa™ Cancun AirJet™', 'Артикул: 54286', '1 300')
