<!DOCTYPE html>
html(lang="ru")
	head
		include ./../sections/_head.pug
		title Bestway | Контакты
	body

		include ./../sections/_header.pug

		.container 
			+breadcrumbs({'items': ['Главная', 'Контакты']}) 

		main.page.contacts 

			.fixed-text контакты

			.container

				.contacts__box 

					.contacts__data 
						h1.main-title.contacts__title 
							span Где нас 
							| найти ?
						.contacts__items
							.contacts__item 
								span.contacts__name График работы 
								.contacts__val
									p Понедельник-Пятница - #[b с 9:00 до 18:00]
									p Перерыв #[b с 13:00 до 14:00]
									p Суббота, Воскресенье - #[b выходной]
							.contacts__item 
								span.contacts__name Телефон
								.contacts__val 
									a.contacts__phone(href="tel:+78006005525") +7 (800) 600-55-25
							.contacts__item 
								span.contacts__name Почта
								.contacts__val 
									a.contacts__mail(href="mailto:info@bestwayrussia.ru") info@bestwayrussia.ru
							.contacts__item 
								span.contacts__name Адрес
								.contacts__val 
									span.contacts__adress 127006, Москва, ул. Долгоруковская, д. 36, с. 3, этаж 6
							.contacts__item 
								span.contacts__name Соц. сети
								.contacts__val
									.contacts-messengers 
										each item in ['icon-telegram.svg','icon-facebook.svg','icon-instagram.svg','icon-twitter.svg','icon-youtube.svg']
											a.contacts-messengers__link(href="#")
												img.contacts-messengers__icon(src="img/" + item, alt="@")
							
					.contacts__map#map



		include ./../sections/_footer.pug

		include ./../sections/_scripts.pug